{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "neverwinter-lockbox-vault",
  "compatibility_date": "2026-07-14",
  "main": "./worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
